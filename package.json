{
  "name": "rx-twitter",
  "version": "2.4.5",
  "description": "",
  "type": "module",
  "main": "index.js",
  "private": true,
  "keywords": [
    "discord",
    "twitter"
  ],
  "homepage": "https://github.com/rx-twitter/rx-twitter#readme",
  "bugs": {
    "url": "https://github.com/rx-twitter/rx-twitter/issues"
  },
  "license": "MIT",
  "author": "t1nyb0x",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rx-twitter/rx-twitter.git"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "start": "node --env-file=.env dist/index.js",
    "start:docker": "node ./dist/index.js",
    "debug": "tsc --noEmit && tsx watch --env-file=.env src/index.ts",
    "clean": "rm -rf dist",
    "compile": "npm run clean && tsc -p . && tsc-alias --resolve-full-paths",
    "compile:test": "tsc -p . --noEmit",
    "build": "npm run build:shared && npm run compile",
    "build:shared": "npm run build --workspace=@rx-twitter/shared",
    "test": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "vitest run tests/e2e",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "lint": "oxlint src/ tests/",
    "format": "oxfmt src/"
  },
  "dependencies": {
    "@discordjs/builders": "^1.9.0",
    "@hono/node-server": "^2.0.4",
    "@rx-twitter/shared": "*",
    "chalk": "^5.3.0",
    "discord.js": "^14.26.3",
    "hono": "^4.12.25",
    "js-yaml": "^5.0.0",
    "redis": "^6.0.0",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@types/js-yaml": "4.0.9",
    "@types/node": "24.13.2",
    "@vitest/coverage-v8": "4.1.9",
    "@vitest/ui": "4.1.9",
    "husky": "9.1.7",
    "lint-staged": "17.0.8",
    "oxfmt": "0.56.0",
    "oxlint": "1.71.0",
    "ts-node": "10.9.2",
    "tsc-alias": "1.8.16",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  }
}
